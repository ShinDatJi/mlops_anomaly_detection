      "patch_size": 78,
      "patches": 8,
      "overlap": 0.5,
      "good_fraction": 0.25,
      "oversampling": true,
      "threshold": "full-auto",
      "threshold_factor": 1,
      "spread": 0.025,
      "height_cropping": 0,
      "width_cropping": 2,
      "random_trans": 0,
      "random_rot": 0,
      "random_trans_sub": 0,
      "random_rot_sub": 0,
      "fill_mode": "reflect",
      "fill_mode_sub": "constant",
      "fill_value": 0,
      "fast_patching": true,
      "random_state": 42
    },
    "metrics": {
      "threshold": 0.051,
      "train_images": {
        "images_good_source": 60,
        "images_bad_source": 15,
        "oversampling": 12,
        "images_good": 784,
        "images_bad": 852
