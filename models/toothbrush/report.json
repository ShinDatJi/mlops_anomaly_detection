      "test_patching_images": {
        "images_good_source": 12,
        "images_bad_source": 15,
        "oversampling": 0,
        "images_good": 384,
        "images_bad": 480
      }
    }
  },
  "modeling": {
    "params": {
      "learning_rate": 0.001,
      "augmentations": {
        "flip": false,
        "brightness": 0,
        "contrast": 0,
        "saturation": [
          0.5,
          0.5
        ],
        "hue": 1
      },
      "center_scaled": false,
      "conv_blocks": [
        {
          "filters": 32,
          "normalization": false
        },
        {
          "filters": 64,
          "dropout": 0.1,
          "normalization": false
        },
        {
          "filters": 128,
          "dropout": 0.2,
          "normalization": false
        },
        {
          "filters": 128,
          "dropout": 0.5,
          "normalization": false
        }
      ],
      "dense_blocks": [
        {
          "units": 128,
          "l2": 0.01,
          "normalization": false,
          "dropout": 0
        }
      ],
      "random_state": 42
    }
  },
  "training": {
    "params": {
      "batch_size": 32,
      "epochs": 50,
      "validation_from_train": false,
      "use_buggy_early_stopping_restore_best_weights": false,
      "early_stopping": {
        "min_delta": 0.01,
        "patience": 5
      },
      "reduce_learning_rate_on_plateau": {
        "min_delta": 0.01,
        "patience": 3,
        "factor": 0.25,
        "cooldown": 2
      },
      "random_state": 42
