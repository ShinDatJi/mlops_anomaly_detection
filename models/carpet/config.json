{
  "preparation": {
    "train_test_split": 0.5,
    "random_state": 42
  },
  "preprocessing": {
    "good_fraction": 0.25,
    "patch_size": 78,
    "patches": 5,
    "spread": 0.025,
    "threshold": "auto",
    "threshold_factor": 1,
    "overlap": 0.5,
    "height_cropping": 0,
    "width_cropping": 0,
    "fast_patching": true,
    "random_trans": 0.5,
    "random_rot": 0.5,
    "random_trans_sub": 0,
    "random_rot_sub": 0,
    "fill_mode": "reflect",
    "fill_mode_sub": "constant",
    "fill_value": 0,
    "random_state": 42
  },
  "modeling": {
    "learning_rate": 0.001,
    "augmentations": {
      "flip": false,
      "brightness": 0.1,
      "contrast": 0.1,
      "saturation": 0.1,
      "hue": 0.1
    },
    "center_scaled": false,
    "conv_blocks": [
      {
        "filters": 32,
        "normalization": false
      },
      {
        "filters": 64,
        "dropout": 0.1,
        "normalization": false
      },
      {
        "filters": 128,
        "dropout": 0.2,
        "normalization": false
      }
    ],
    "dense_blocks": [
      {
        "units": 128,
        "l2": 0.01,
        "normalization": false,
        "dropout": 0
      }
    ],
    "random_state": 42
  },
  "training": {
    "batch_size": 32,
    "validation_from_train": false,
    "epochs": 50,
    "use_buggy_early_stopping_restore_best_weights": false,
    "early_stopping": {
      "min_delta": 0.01,
      "patience": 5
    },
    "reduce_learning_rate_on_plateau": {
      "min_delta": 0.01,
      "patience": 3,
      "factor": 0.25,
      "cooldown": 2
    },
    "random_state": 42
  },
  "evaluation": {
    "threshold": 0.5
  }
}