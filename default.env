# This file is for development only. Do not use it in production. For production settings, please use app specific .env files.

# Modeling settings

CATEGORY=bottle
VERSION=v1

CONFIG_FROM_MODEL_REGISTRY=1
CONFIG_FROM_MODEL_REGISTRY_CATEGORY=${CATEGORY}
CONFIG_FROM_MODEL_REGISTRY_VERSION=pretrained
CONFIG_FROM_MODEL_REGISTRY_ALIAS=champion
CONFIG_FILE=./apps/modeling/default.config.json

# MAX_EPOCHS=3

# Project settings

# Windows users
# MY_PROJECT_ROOT=/c/Users/.../mlops_anomaly_detection
# Linux users
MY_PROJECT_ROOT=${PWD}

MY_DATA_RAW_PATH=./data/raw/${CATEGORY}

# MinIO settings
MY_MINIO_USER=minio
MY_MINIO_PASSWORD=minio123 # at least 8 chars
MY_MINIO_PORT=9011

# mlflow settings
MY_MLFLOW_USER=mlflow
MY_MLFLOW_PASSWORD=mlflowpassword # at least 12 chars
MY_MLFLOW_PORT=5000

# airflow settings
MY_AIRFLOW_USERNAME=airflow
MY_AIRFLOW_PASSWORD=airflow
MY_AIRFLOW_PORT=8080

# api settings
MY_API_ADMIN_KEY=projectAdmin
MY_API_TEST_KEY=ProjectTest
MY_API_PORT=8000

# prometheus settings
MY_PROMETHEUS_PORT=9090

# grafana settings
MY_GRAFANA_USER=admin
MY_GRAFANA_PASSWORD=admin
MY_GRAFANA_PORT=3001
