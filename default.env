# Modeling settings

CATEGORY=bottle
VERSION=v1

CONFIG_FROM_MODEL_REGISTRY=1
CONFIG_FROM_MODEL_REGISTRY_CATEGORY=${CATEGORY}
CONFIG_FROM_MODEL_REGISTRY_VERSION=pretrained
CONFIG_FROM_MODEL_REGISTRY_ALIAS=champion
CONFIG_FILE=./apps/modeling/default.config.json

# MAX_EPOCHS=3

# Project settings

# Windows users
# MY_PROJECT_ROOT=/c/Users/.../mlops_anomaly_detection

# Linux users
MY_PROJECT_ROOT=${PWD}

MY_DATA_RAW_PATH=./data/raw/${CATEGORY}

# MinIO settings
MY_MINIO_USER=minio
MY_MINIO_PASSWORD=minio123 # at least 8 chars
MY_MINIO_PORT=9011

# mlflow settings
MY_MLFLOW_USER=mlflow
MY_MLFLOW_PASSWORD=mlflowpassword # at least 12 chars
MY_MLFLOW_PORT=5000

# airflow settings
MY_AIRFLOW_USERNAME=airflow
MY_AIRFLOW_PASSWORD=airflow
MY_AIRFLOW_PORT=8080
