# Development settings

MY_AIRFLOW_USERNAME=${MY_AIRFLOW_USERNAME:-airflow}
MY_AIRFLOW_PASSWORD=${MY_AIRFLOW_PASSWORD:-airflow}
MY_AIRFLOW_PORT=${MY_AIRFLOW_PORT:-8080}

MY_PROJECT_ROOT=${MY_PROJECT_ROOT:-${PWD}}

# Production settings

# Docker
COMPOSE_PROJECT_NAME=airflow
EXPOSED_AIRFLOW_WEBSERVER_PORT=${MY_AIRFLOW_PORT}

# Airflow
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./apps/airflow
_AIRFLOW_WWW_USER_USERNAME=${MY_AIRFLOW_USERNAME}
_AIRFLOW_WWW_USER_PASSWORD=${MY_AIRFLOW_PASSWORD}

# Project
PROJECT_ROOT=${MY_PROJECT_ROOT}
DATA_PROJECT_PATH=./apps/data
MODELING_PROJECT_PATH=./apps/modeling

# Modeling
MODELING_DEFAULT_CONFIG_FILE=./apps/modeling/default.config.json
MODELING_CONFIG_PATH=./reports/modeling
MODELING_CONFIG=config.json
