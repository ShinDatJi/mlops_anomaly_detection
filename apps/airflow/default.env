COMPOSE_PROJECT_NAME=airflow

AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=./apps/airflow
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

EXPOSED_AIRFLOW_WEBSERVER_PORT=8080

PROJECT_ROOT=${PWD}
# For windows users, you have to manually set the PROJECT_ROOT to the absolute path of your project directory
# PROJECT_ROOT=/c/Users/.../mlops_anomaly_detection
DATA_PROJECT_PATH=./apps/data
MODELING_PROJECT_PATH=./apps/modeling

DEFAULT_CONFIG_FILE=./apps/modeling/default.config.json
REPORTS_MODELING_PATH=./reports/modeling
REPORTS_CONFIG=config.json
