# Monitoring stack ports
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Grafana bootstrap
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Paths (host)
MONITORING_REPORTS_PATH=./reports/monitoring
MODELS_PATH=./models

# Future MLflow context (used by Evidently job)
MLFLOW_TRACKING_URI=http://mlflow-server:5000
MLFLOW_MODEL_NAME=anomaly-detector
MLFLOW_MODEL_VERSION=unknown
MLFLOW_RUN_ID=unknown

# Evidently schedule
EVIDENTLY_INTERVAL_SECONDS=300

# Monitoring mode
MONITORING_MODE=minimal
ENABLE_DETAILED_DATA_QUALITY_METRICS=false
ENABLE_LABEL_BASED_METRICS=false
