# Development settings

MY_PROMETHEUS_PORT=${MY_PROMETHEUS_PORT:-9090}

MY_GRAFANA_USER=${MY_GRAFANA_USER:-admin}
MY_GRAFANA_PASSWORD=${MY_GRAFANA_PASSWORD:-admin}
MY_GRAFANA_PORT=${MY_GRAFANA_PORT:-3001}

# Production settings

# Monitoring stack ports
PROMETHEUS_PORT=${MY_PROMETHEUS_PORT}
GRAFANA_PORT=${MY_GRAFANA_PORT}

# Grafana bootstrap
GRAFANA_ADMIN_USER=${MY_GRAFANA_USER}
GRAFANA_ADMIN_PASSWORD=${MY_GRAFANA_PASSWORD}

# Paths (host)
MONITORING_REPORTS_PATH=./reports/monitoring
MODELS_PATH=./models

# Evidently schedule
EVIDENTLY_INTERVAL_SECONDS=30

# Monitoring mode
MONITORING_MODE=minimal
ENABLE_DETAILED_DATA_QUALITY_METRICS=false
ENABLE_LABEL_BASED_METRICS=false
