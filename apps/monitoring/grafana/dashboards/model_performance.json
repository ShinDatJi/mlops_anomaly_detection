{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {"expr": "evidently_anomaly_rate{category=\"all\"}", "legendFormat": "current", "refId": "A"},
        {"expr": "evidently_reference_positive_rate{category=\"all\"}", "legendFormat": "reference", "refId": "B"}
      ],
      "title": "Global Anomaly Rate vs Reference",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {"expr": "evidently_output_drift_score{category=\"all\"}", "legendFormat": "output drift", "refId": "A"}
      ],
      "title": "Output Drift Score",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "id": 3,
      "targets": [
        {"expr": "evidently_anomaly_rate{category!=\"all\"}", "legendFormat": "{{category}}", "refId": "A"}
      ],
      "title": "Per-Category Anomaly Rate",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "id": 4,
      "targets": [
        {"expr": "evidently_model_f1_score{category=\"all\"}", "legendFormat": "f1", "refId": "A"}
      ],
      "title": "Observed F1 (when labels exist)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["monitoring", "performance"],
  "templating": {"list": []},
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Model Performance",
  "uid": "model-performance",
  "version": 3,
  "weekStart": ""
}
