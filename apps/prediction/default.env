# Development settings

MY_API_ADMIN_KEY=${MY_API_ADMIN_KEY:-projectAdmin}
MY_API_TEST_KEY=${MY_API_TEST_KEY:-ProjectTest}
MY_API_PORT=${MY_API_PORT:-8000}

MY_MLFLOW_USER=${MY_MLFLOW_USER:-mlflow}
MY_MLFLOW_PASSWORD=${MY_MLFLOW_PASSWORD:-mlflowpassword}

# Production settings

PREDICTION_PORT=${MY_API_PORT}
LOG_LEVEL=INFO
API_KEY_ADMIN=${MY_API_ADMIN_KEY}
API_KEY_TEST=${MY_API_TEST_KEY}

MODELS_PATH=./models

MONITORING_REPORTS_PATH=./reports/monitoring
VIRTUAL_MONITORING_REPORTS_PATH=./reports/monitoring
MONITORING_EVENTS_FILE=inference_events/events.jsonl

MLFLOW_MODEL_NAME=anomaly-detector
MLFLOW_MODEL_VERSION=unknown
MLFLOW_RUN_ID=unknown

MONITORING_MODE=minimal

# mlflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_TRACKING_USERNAME=${MY_MLFLOW_USER}
MLFLOW_TRACKING_PASSWORD=${MY_MLFLOW_PASSWORD}
