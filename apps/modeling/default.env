# Modeling default environment

COMPOSE_PROJECT_NAME=modeling

AIRFLOW_UID=50000

CATEGORY=${CATEGORY:-bottle}
VERSION=${VERSION:-v1}

CONFIG_FILE=./apps/modeling/default.config.json
CONFIG_FROM_MODEL_REGISTRY=1
CONFIG_FROM_MODEL_REGISTRY_CATEGORY=${CATEGORY}
CONFIG_FROM_MODEL_REGISTRY_VERSION=pretrained
CONFIG_FROM_MODEL_REGISTRY_ALIAS=champion

DATA_PATH=./data/processed/${CATEGORY}_${VERSION}

DATA_CLEAN_DB=clean.csv
DATA_TRAIN_DB=train.csv
DATA_TEST_DB=test.csv

DATA_TRAIN_DIR=train
DATA_TEST_DIR=test
DATA_TEST_PATCHING_DIR=test_patching

REPORTS_PATH=./reports/modeling/${CATEGORY}_${VERSION}
REPORTS_LOADING_PATH=./reports/modeling/${CATEGORY}_${VERSION}/loading
REPORTS_PREPROCESSING_PATH=./reports/modeling/${CATEGORY}_${VERSION}/preprocessing
REPORTS_TRAINING_PATH=./reports/modeling/${CATEGORY}_${VERSION}/training
REPORTS_EVALUATION_PATH=./reports/modeling/${CATEGORY}_${VERSION}/evaluation

REPORTS_CONFIG=config.json
REPORTS_REPORT=report.json
REPORTS_MODEL=model.keras

MODELS_PATH=./models
MODELS_CONFIG=config.json
MODELS_REPORT=report.json
MODELS_MODEL=model.keras

S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
S3_BUCKET=${CATEGORY}
S3_DATA_RAW_PATH=${VERSION}/data/raw
S3_DATA_FILE=${VERSION}/data.csv

MLFLOW_TRACKING_URI=http://mlflow:5000

# MAX_EPOCHS=3
