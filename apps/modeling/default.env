# Development settings

# params
CATEGORY=${CATEGORY:-bottle}
VERSION=${VERSION:-v1}

#config
CONFIG_FROM_MODEL_REGISTRY=${CONFIG_FROM_MODEL_REGISTRY:-1}
CONFIG_FROM_MODEL_REGISTRY_CATEGORY=${CONFIG_FROM_MODEL_REGISTRY_CATEGORY:-${CATEGORY}}
CONFIG_FROM_MODEL_REGISTRY_VERSION=${CONFIG_FROM_MODEL_REGISTRY_VERSION:-pretrained}
CONFIG_FROM_MODEL_REGISTRY_ALIAS=${CONFIG_FROM_MODEL_REGISTRY_ALIAS:-champion}
CONFIG_FILE=${CONFIG_FILE:-./apps/modeling/default.config.json}

MAX_EPOCHS=${MAX_EPOCHS}

# minio
MY_MINIO_USER=${MY_MINIO_USER:-minio}
MY_MINIO_PASSWORD=${MY_MINIO_PASSWORD:-minio123}

# mlflow
MY_MLFLOW_USER=${MY_MLFLOW_USER:-mlflow}
MY_MLFLOW_PASSWORD=${MY_MLFLOW_PASSWORD:-mlflowpassword}

# Production settings

COMPOSE_PROJECT_NAME=modeling

AIRFLOW_UID=50000

# data
DATA_PATH=./data/processed/${CATEGORY}_${VERSION}
DATA_CLEAN_DB=clean.csv
DATA_TRAIN_DB=train.csv
DATA_TEST_DB=test.csv
DATA_TRAIN_DIR=train
DATA_TEST_DIR=test
DATA_TEST_PATCHING_DIR=test_patching

# reports
REPORTS_PATH=./reports/modeling/${CATEGORY}_${VERSION}
REPORTS_LOADING_PATH=./reports/modeling/${CATEGORY}_${VERSION}/loading
REPORTS_PREPROCESSING_PATH=./reports/modeling/${CATEGORY}_${VERSION}/preprocessing
REPORTS_TRAINING_PATH=./reports/modeling/${CATEGORY}_${VERSION}/training
REPORTS_EVALUATION_PATH=./reports/modeling/${CATEGORY}_${VERSION}/evaluation
REPORTS_CONFIG=config.json
REPORTS_REPORT=report.json
REPORTS_MODEL=model.keras

# models
MODELS_PATH=./models
MODELS_CONFIG=config.json
MODELS_REPORT=report.json
MODELS_MODEL=model.keras

# s3
S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=${MY_MINIO_USER}
AWS_SECRET_ACCESS_KEY=${MY_MINIO_PASSWORD}
S3_BUCKET=${CATEGORY}
S3_DATA_RAW_PATH=${VERSION}/data/raw
S3_DATA_FILE=${VERSION}/data.csv

# mlflow
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_TRACKING_USERNAME=${MY_MLFLOW_USER}
MLFLOW_TRACKING_PASSWORD=${MY_MLFLOW_PASSWORD}
