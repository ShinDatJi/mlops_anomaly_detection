# Development settings

CATEGORY=${CATEGORY:-bottle}
VERSION=${VERSION:-v1}

MY_DATA_RAW_PATH=${MY_DATA_RAW_PATH:-./data/raw/${CATEGORY}}

MY_MINIO_USER=${MY_MINIO_USER:-minio}
MY_MINIO_PASSWORD=${MY_MINIO_PASSWORD:-minio123}

# Production settings

COMPOSE_PROJECT_NAME=data

DATA_RAW_PATH=${MY_DATA_RAW_PATH}

# S3
S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=${MY_MINIO_USER}
AWS_SECRET_ACCESS_KEY=${MY_MINIO_PASSWORD}
S3_BUCKET=${CATEGORY}
S3_DATA_RAW_PATH=${VERSION}/data/raw
S3_DATA_FILE=${VERSION}/data.csv
