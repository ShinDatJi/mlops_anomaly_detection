# Data default environment

COMPOSE_PROJECT_NAME=data

CATEGORY=${CATEGORY:-bottle}
VERSION=${VERSION:-v1}

DATA_RAW_PATH=./data/raw/${CATEGORY}

S3_ENDPOINT=http://minio:9000
AWS_ACCESS_KEY_ID=minio
AWS_SECRET_ACCESS_KEY=minio123
S3_BUCKET=${CATEGORY}
S3_DATA_RAW_PATH=${VERSION}/data/raw
S3_DATA_FILE=${VERSION}/data.csv
